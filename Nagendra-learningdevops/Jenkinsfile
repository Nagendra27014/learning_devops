pipeline {
    agent any

    stages {
        stage('Clone') {
            steps {
                git url: 'git@github.com:Nagendra27014/learning_devops.git',
                    credentialsId: 'github-ssh'
            }
        }

        stage('Build') {
            steps {
                echo 'Build stage running'
            }
        }
    }
}





























