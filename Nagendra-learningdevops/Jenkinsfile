pipeline {
    agent any

    environment {
        APP_NAME = "my-app"
    }

    git add 
git commit -m "test webhook"
git push

    stages {
        stage('Clone') {
            steps {
                git branch: 'main', url: 'https://github.com/Nagendra27014/learning_devops.git'
            }
        }

        stage('Build') {
            steps {
                sh 'echo "Building $APP_NAME"'
            }
        }

        stage('Test') {
            steps {
                sh 'echo "Running tests"'
            }
        }

        stage('Package') {
            steps {
                sh 'echo "Packaging app"'
            }
        }
    }
}
